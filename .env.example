APP_NAME="PSAU Parking"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=psau_security
DB_USERNAME=root
DB_PASSWORD=

# ─── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@psau-parking.edu.ph"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage ───────────────────────────────────────────────────────────────────
# Run: php artisan storage:link
# Uploaded files (vehicle photos, OR/CR docs, violation photos) are stored
# under storage/app/public and served via the public/storage symlink.

# ─── OCR (Tesseract) ───────────────────────────────────────────────────────────
# Tesseract must be installed on the server for plate number extraction.
# Install: sudo apt-get install tesseract-ocr  (Ubuntu/Debian)
# If not installed, OCR will be skipped and plate number defaults to UNKNOWN.

VITE_APP_NAME="${APP_NAME}"
